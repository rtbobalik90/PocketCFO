/* =========================================================
   Pocket CFO — styles.css
   "Banker's ledger after dark": deep green-black surfaces,
   brass gold accent, mono ledger figures.
   Mobile-first, iOS safe-area aware, reduced-motion safe.
   ========================================================= */

:root {
  --bg: #0B100E;
  --surface: #121A16;
  --raised: #18241F;
  --edge: rgba(233, 180, 76, 0.10);
  --hair: rgba(140, 160, 150, 0.16);
  --text: #E9EFEA;
  --muted: #8CA096;
  --gold: #E9B44C;
  --gold-deep: #B8862F;
  --income: #43C79A;
  --spend: #E5675A;
  --info: #59B7C4;
  --radius: 14px;
  --font-display: 'Sora', system-ui, sans-serif;
  --font-body: 'Inter', system-ui, -apple-system, sans-serif;
  --font-mono: 'IBM Plex Mono', ui-monospace, Menlo, monospace;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

html { color-scheme: dark; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  background-image: radial-gradient(1200px 500px at 50% -200px, rgba(233,180,76,.05), transparent);
  color: var(--text);
  font-size: 15px;
  line-height: 1.45;
  min-height: 100dvh;
  padding-bottom: calc(72px + env(safe-area-inset-bottom));
}

.mono { font-family: var(--font-mono); font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }
.pos { color: var(--income); }
.neg { color: var(--spend); }
.gold-t { color: var(--gold); }
.sub { color: var(--muted); font-size: 12.5px; }
.hidden { display: none !important; }
.right { margin-left: auto; }
.top6 { margin-top: 6px; }
.chev { color: var(--muted); font-weight: 400; margin-left: auto; }

/* ---------- screens ---------- */
.screen { display: none; padding: calc(12px + env(safe-area-inset-top)) 14px 20px; max-width: 560px; margin: 0 auto; }
.screen.active { display: block; animation: fadein .18s ease; }
@keyframes fadein { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
@media (prefers-reduced-motion: reduce) { .screen.active { animation: none; } }

/* ---------- header ---------- */
.apphead { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 4px 0 14px; }
.apphead h2 { font-family: var(--font-display); font-size: 19px; font-weight: 700; letter-spacing: -0.01em; }
.brand { font-family: var(--font-display); font-weight: 800; font-size: 13px; letter-spacing: 0.24em; color: var(--gold); }
.date { color: var(--muted); font-size: 12.5px; margin-top: 2px; }
.headbtns { display: flex; gap: 8px; }
.iconbtn {
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--surface); border: 1px solid var(--hair); color: var(--text);
  font-size: 16px; cursor: pointer;
}
.iconbtn:disabled { opacity: .35; }
.monthnav { display: flex; align-items: center; gap: 10px; }
.monthnav h2 { min-width: 150px; text-align: center; font-size: 16px; }

/* ---------- coach strip (signature) ---------- */
.coachstrip {
  display: flex; gap: 10px; align-items: baseline;
  background: linear-gradient(90deg, rgba(233,180,76,.10), rgba(233,180,76,.03));
  border-left: 3px solid var(--gold);
  border-radius: 6px;
  padding: 10px 12px;
  margin-bottom: 14px;
  cursor: pointer;
}
.cs-label { font-family: var(--font-display); font-size: 10px; font-weight: 800; letter-spacing: .2em; color: var(--gold); flex-shrink: 0; }
.cs-text { font-size: 13.5px; color: var(--text); }

/* ---------- cards ---------- */
.card {
  background: var(--surface);
  border: 1px solid var(--edge);
  border-radius: var(--radius);
  padding: 14px;
  margin-bottom: 12px;
}
.card.tap { cursor: pointer; }
.card.tap:active { background: var(--raised); }
.card-title {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--font-display); font-size: 12px; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase; color: var(--muted);
  margin-bottom: 10px;
}
.card.empty { text-align: center; padding: 26px 18px; }
.card.empty h3 { font-family: var(--font-display); margin-bottom: 6px; }
.card.empty p { color: var(--muted); font-size: 13.5px; margin-bottom: 14px; }

/* hero */
.card.hero { padding: 18px 16px 14px; }
.hero-label { font-family: var(--font-display); font-size: 10.5px; font-weight: 800; letter-spacing: .22em; color: var(--muted); }
.hero-figure { font-size: 38px; font-weight: 600; color: var(--text); margin: 4px 0 8px; }
.hero-sub { display: flex; justify-content: space-between; color: var(--muted); font-size: 12px; margin-top: 6px; }
.spark { width: 100%; height: 56px; display: block; }

/* stat row */
.statrow { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 12px; }
.statrow.tight { margin-bottom: 8px; }
.stat { background: var(--surface); border: 1px solid var(--edge); border-radius: 12px; padding: 10px; }
.stat-label { font-size: 9.5px; font-weight: 700; letter-spacing: .12em; color: var(--muted); font-family: var(--font-display); }
.stat-val { font-size: 16px; margin-top: 3px; }

/* rows / lists */
.rowline { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; padding: 7px 0; border-bottom: 1px solid var(--hair); }
.rowline:last-child { border-bottom: none; }
.rowline .sub { display: block; }
.bigline { display: flex; align-items: baseline; gap: 10px; font-size: 24px; margin: 2px 0 8px; }
.bigline small { font-size: 13px; color: var(--muted); }
.minitags, .chips { display: flex; flex-wrap: wrap; gap: 6px; }
.chips { padding: 0 2px; }
.tag {
  font-size: 11.5px; color: var(--muted);
  background: var(--raised); border: 1px solid var(--hair);
  border-radius: 999px; padding: 4px 10px; cursor: pointer; font-family: var(--font-body);
}
.tag.on { color: var(--bg); background: var(--gold); border-color: var(--gold); font-weight: 600; }
.rec { color: var(--info); font-style: normal; }

/* transactions */
.datehead { font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin: 14px 2px 6px; }
.txrow {
  display: flex; justify-content: space-between; align-items: center; gap: 10px;
  width: 100%; text-align: left;
  background: var(--surface); border: 1px solid var(--edge); border-radius: 12px;
  padding: 11px 12px; margin-bottom: 6px; color: var(--text);
  font: inherit; cursor: pointer;
}
.txrow:active { background: var(--raised); }
.txmain b { display: block; font-weight: 600; font-size: 14px; }
.txmain .sub { font-size: 11.5px; }

/* progress bars */
.progress { height: 8px; background: var(--raised); border-radius: 999px; overflow: hidden; margin: 4px 0 8px; }
.bar { height: 100%; border-radius: 999px; transition: width .4s ease; }
.bar.gold { background: linear-gradient(90deg, var(--gold-deep), var(--gold)); }
.bar.teal { background: linear-gradient(90deg, #2E9C78, var(--income)); }

/* alerts */
.alert { border-radius: 10px; padding: 9px 11px; font-size: 13px; margin-bottom: 7px; border: 1px solid; }
.alert:last-child { margin-bottom: 0; }
.alert.bad  { color: #F3B3AB; background: rgba(229,103,90,.10); border-color: rgba(229,103,90,.3); }
.alert.warn { color: #F0D9A6; background: rgba(233,180,76,.08); border-color: rgba(233,180,76,.28); }
.alert.info { color: #B4DEE6; background: rgba(89,183,196,.08); border-color: rgba(89,183,196,.28); }
.alert.good { color: #B8E8D4; background: rgba(67,199,154,.08); border-color: rgba(67,199,154,.28); }

/* buttons */
.btn {
  font: 600 14px var(--font-body);
  color: var(--text); background: var(--raised);
  border: 1px solid var(--hair); border-radius: 11px;
  padding: 11px 16px; cursor: pointer;
}
.btn.gold { color: #14100A; background: linear-gradient(180deg, #F0C264, var(--gold)); border-color: var(--gold-deep); }
.btn.danger { color: #F3B3AB; border-color: rgba(229,103,90,.4); }
.btn.small { padding: 8px 12px; font-size: 13px; border-radius: 9px; }
.btn:disabled { opacity: .4; cursor: default; }
.btn:not(:disabled):active { transform: translateY(1px); }
.row { display: flex; align-items: center; }
.row.gap { gap: 8px; }
.row.end { justify-content: flex-end; margin-top: 14px; }
.row.wrap { flex-wrap: wrap; }
.grow { flex: 1; }

/* segmented control */
.seg { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
.seg button {
  font: 600 13.5px var(--font-display); color: var(--muted);
  background: var(--raised); border: 1px solid var(--hair); border-radius: 11px;
  padding: 10px; cursor: pointer; text-align: center;
}
.seg button span { display: block; font: 400 11px var(--font-body); margin-top: 2px; }
.seg button.on { color: #14100A; background: linear-gradient(180deg, #F0C264, var(--gold)); border-color: var(--gold-deep); }
.seg button.on span { color: rgba(20,16,10,.7); }

/* fields */
.fieldrow { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 8px 0; font-size: 13.5px; }
.fieldrow.col { flex-direction: column; align-items: stretch; gap: 5px; }
.fieldrow > span { color: var(--muted); font-size: 12px; font-weight: 600; letter-spacing: .03em; }
input, select {
  font: 15px var(--font-body); color: var(--text);
  background: var(--raised); border: 1px solid var(--hair);
  border-radius: 10px; padding: 10px 12px; width: 100%;
  appearance: none;
}
input:focus, select:focus, button:focus-visible { outline: 2px solid var(--gold); outline-offset: 1px; }
input.mono { font-family: var(--font-mono); }
.fieldrow:not(.col) input { max-width: 130px; text-align: right; }
.checkrow { display: flex; gap: 8px; align-items: center; font-size: 13.5px; margin: 10px 0; }
.checkrow input { width: auto; }
.searchrow { display: flex; gap: 8px; align-items: center; margin: 12px 0 4px; }
.calcrows div { display: flex; justify-content: space-between; padding: 2px 0; }

/* charts */
.bars { width: 100%; height: 130px; display: block; }
.payoff { width: 100%; height: 150px; display: block; margin-top: 8px; }
.donutwrap { display: grid; grid-template-columns: 132px 1fr; gap: 12px; align-items: center; }
.donut { width: 132px; height: 132px; }
.legend { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.legenditem {
  display: flex; align-items: center; gap: 7px;
  font: 12.5px var(--font-body); color: var(--text);
  background: none; border: none; padding: 3px 6px; border-radius: 7px;
  cursor: pointer; text-align: left;
}
.legenditem b { margin-left: auto; font-size: 12px; color: var(--muted); }
.legenditem.on { background: var(--raised); }
.legenditem .dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }

/* chat */
.chat { display: flex; flex-direction: column; gap: 8px; min-height: 40vh; max-height: 56vh; overflow-y: auto; padding: 4px 0 10px; }
.chatmsg { max-width: 88%; padding: 10px 13px; border-radius: 14px; font-size: 14px; white-space: pre-wrap; }
.chatmsg.coach { align-self: flex-start; background: var(--surface); border: 1px solid var(--edge); border-bottom-left-radius: 4px; }
.chatmsg.user { align-self: flex-end; background: rgba(233,180,76,.14); border: 1px solid rgba(233,180,76,.25); border-bottom-right-radius: 4px; }
.chatinput { display: flex; gap: 8px; margin: 6px 0 10px; }

/* modal */
.modal-wrap {
  position: fixed; inset: 0; z-index: 50;
  background: rgba(6,9,8,.72); backdrop-filter: blur(3px);
  display: flex; align-items: flex-end; justify-content: center;
}
.modal {
  width: 100%; max-width: 560px;
  background: var(--surface); border: 1px solid var(--edge);
  border-radius: 18px 18px 0 0;
  padding: 18px 16px calc(18px + env(safe-area-inset-bottom));
  animation: slideup .22s ease;
}
@keyframes slideup { from { transform: translateY(30px); opacity: 0; } to { transform: none; opacity: 1; } }
@media (prefers-reduced-motion: reduce) { .modal { animation: none; } }
.modal h3 { font-family: var(--font-display); margin-bottom: 8px; }
@media (min-width: 561px) { .modal-wrap { align-items: center; } .modal { border-radius: 18px; } }

/* toast */
.toast {
  position: fixed; left: 50%; bottom: calc(86px + env(safe-area-inset-bottom));
  transform: translateX(-50%) translateY(8px); opacity: 0;
  background: var(--raised); border: 1px solid var(--gold-deep); color: var(--text);
  border-radius: 999px; padding: 9px 16px; font-size: 13px; z-index: 60;
  transition: all .25s ease; max-width: 88vw; text-align: center;
}
.toast.show { transform: translateX(-50%); opacity: 1; }

/* ---------- tab bar ---------- */
.tabbar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
  display: grid; grid-template-columns: repeat(5, 1fr);
  background: rgba(14,20,17,.92); backdrop-filter: blur(14px);
  border-top: 1px solid var(--hair);
  padding: 6px 8px calc(6px + env(safe-area-inset-bottom));
  max-width: 100%;
}
.tabbar button {
  background: none; border: none; color: var(--muted);
  font: 600 10px var(--font-display); letter-spacing: .04em;
  padding: 6px 0 4px; cursor: pointer; border-radius: 10px;
}
.tabbar .ico { display: block; font-size: 19px; margin-bottom: 2px; }
.tabbar button.active { color: var(--gold); }
